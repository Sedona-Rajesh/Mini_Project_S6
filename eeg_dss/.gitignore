# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Local/editor metadata
.vscode/
.idea/
*.log

# Project outputs and runtime logs
logs/
outputs/
eeg_dss/app/logs/
eeg_dss/app/outputs/

